<view class="profile-page">
  <view class="profile-header">
    <view class="avatar-section">
      <image class="profile-avatar" src="{{userInfo.avatarUrl || '/assets/icons/default_avatar.png'}}" mode="aspectFill" />
      <view class="profile-meta">
        <text class="profile-name">{{userInfo.nickName || '微信用户'}}</text>
        <view class="verified-tag" wx:if="{{userInfo.idCardVerified}}">✔ 已实名认证</view>
        <view class="verified-tag unverified" wx:else bind:tap="goAuth">去认证 &gt;</view>
      </view>
    </view>
    <view class="profile-stats">
      <view class="stat-item">
        <text class="stat-num">{{userInfo.tripCountAsDriver || 0}}</text>
        <text class="stat-label">发布行程</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{userInfo.tripCountAsPassenger || 0}}</text>
        <text class="stat-label">搭车次数</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{userInfo.ratingCount || 0}}</text>
        <text class="stat-label">评价</text>
      </view>
    </view>
  </view>

  <view class="menu-group card">
    <view class="menu-item" bind:tap="goOilPrice">
      <text class="menu-icon">⛽</text>
      <text class="menu-text">实时油价</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bind:tap="goVehicle">
      <text class="menu-icon">🚗</text>
      <text class="menu-text">车辆管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bind:tap="goAuth">
      <text class="menu-icon">🪪</text>
      <text class="menu-text">实名认证</text>
      <text class="menu-arrow">›</text>
      <text class="menu-status {{userInfo.idCardVerified ? 'done' : ''}}">
        {{userInfo.idCardVerified ? '已完成' : '未认证'}}
      </text>
    </view>

  </view>

  <view class="menu-group card">
    <view class="menu-item" bind:tap="contactService">
      <text class="menu-icon">💬</text>
      <text class="menu-text">联系客服</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bind:tap="showAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于老乡同行</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
