<view class="page-container">
  <view class="tabs">
    <view class="tab {{activeTab === 'driver' ? 'active' : ''}}" data-tab="driver" bind:tap="switchTab">
      🚗 我发布的
    </view>
    <view class="tab {{activeTab === 'passenger' ? 'active' : ''}}" data-tab="passenger" bind:tap="switchTab">
      🙋 我申请的
    </view>

    <view class="tab {{activeTab === 'request' ? 'active' : ''}}" data-tab="request" bind:tap="switchTab">
      📋 我求车的
    </view>  </view>

  <view class="status-filters" wx:if="{{activeTab !== 'request'}}">
    <view class="status-filter {{activeStatus === '' ? 'active' : ''}}" data-status="" bind:tap="filterStatus">全部</view>
    <view class="status-filter {{activeStatus === 'recruiting' ? 'active' : ''}}" data-status="recruiting" bind:tap="filterStatus">招募中</view>
    <view class="status-filter {{activeStatus === 'departed' ? 'active' : ''}}" data-status="departed" bind:tap="filterStatus">已出发</view>
    <view class="status-filter {{activeStatus === 'completed' ? 'active' : ''}}" data-status="completed" bind:tap="filterStatus">已完成</view>
  </view>

  <view class="trip-list" wx:if="{{tripList.length > 0}}">
        <view wx:for="{{tripList}}" wx:key="_id" class="trip-item card">
      <!-- 求车卡片 -->
      <block wx:if="{{item._type == 'request'}}">
        <view class="trip-header">
          <text class="trip-route">{{item.fromCity}} → {{item.toCity}}</text>
          <text wx:if="{{item.status === 'active'}}" class="trip-status status-active">待确认</text>
          <text wx:elif="{{item.status === 'invited'}}" class="trip-status status-invited">已邀请</text>
          <text wx:elif="{{item.status === 'confirmed'}}" class="trip-status status-confirmed">已确认</text>
          <text wx:elif="{{item.status === 'cancelled'}}" class="trip-status status-cancelled">已取消</text>
          <text wx:else class="trip-status status-active">待确认</text>
        </view>
        <view class="trip-date-time">
          <text>📅 {{item._dateDisplay}}</text>
        </view>
        <view class="trip-seats">
          <text>👥 {{item.passengers}}人 求同行</text>
          <text wx:if="{{item.contactPhone && (item.status === 'confirmed' || item.status === 'invited')}}" class="trip-phone">☎ {{item.contactPhone}}</text>
          <text wx:elif="{{item.contactPhone}}" class="trip-phone masked">☎ {{item.maskedContactPhone}}</text>
          <text wx:elif="{{item.contactPhone}}" class="trip-phone masked">☎ {{item.maskedContactPhone}}</text>
          <text wx:elif="{{item.contactPhone}}" class="trip-phone masked">☎ {{item.maskedContactPhone}}</text>
        </view>
        <view class="trip-actions">
          <button class="btn-delete" catch:tap="deleteRequest" data-id="{{item._id}}">删除</button>
        </view>
        <!-- Phone view approval -->
        <view class="phone-approval-section" wx:if="{{pendingPhoneRequests.length > 0}}">
          <text class="phone-approval-title">📞 联系方式查看申请</text>
          <view class="phone-approval-item" wx:for="{{pendingPhoneRequests}}" wx:key="_id">
            <text class="phone-approval-name">{{item.requesterNickName}} 申请查看你的联系方式</text>
            <view class="phone-approval-actions">
              <button class="btn-approve" catch:tap="showPhoneRequestApproval" data-reqid="{{item.tripId}}" data-name="{{item.requesterNickName}}" data-requesteropenid="{{item.requesterOpenId}}">处理</button>
            </view>
          </view>
        </view>
        <!-- Phone view approval -->
        <view class="phone-approval-section" wx:if="{{pendingPhoneRequests.length > 0}}">
          <text class="phone-approval-title">📞 联系方式查看申请</text>
          <view class="phone-approval-item" wx:for="{{pendingPhoneRequests}}" wx:key="_id">
            <text class="phone-approval-name">{{item.requesterNickName}} 申请查看你的联系方式</text>
            <view class="phone-approval-actions">
              <button class="btn-approve" catch:tap="showPhoneRequestApproval" data-reqid="{{item.tripId}}" data-name="{{item.requesterNickName}}" data-requesteropenid="{{item.requesterOpenId}}">处理</button>
            </view>
          </view>
        </view>
      </block>
      <!-- 车源卡片 -->
      <block wx:else>
        <view bind:tap="goDetail" data-id="{{item._id}}">
          <view class="trip-header">
            <text class="trip-route">{{item.from.city}} → {{item.to.city}}</text>
            <text class="trip-status status-{{item.status}}">{{statusText(item.status)}}</text>
          </view>
          <view wx:if="{{item.myRole === 'passenger'}}" class="trip-my-status">
            <text class="my-status-tag status-{{item.myStatus}}">{{myStatusText(item.myStatus)}}</text>
          </view>

          <view class="trip-date-time">
            <text>📅 {{item._dateDisplay}}</text>
          </view>
          <view class="trip-seats">
            <text>🪑 剩余 {{item.remainingSeats}} 座</text>
            <text class="trip-price">{{formatPrice(item.price)}}</text>
          </view>
        </view>
        <view wx:if="{{item.myRole === 'passenger' && item.myStatus === 'invited'}}" class="trip-actions">
          <button class="btn-confirm" catch:tap="confirmInvite" data-id="{{item._id}}">确认同行</button>
          <button class="btn-reject" catch:tap="cancelApplication" data-id="{{item._id}}">拒绝</button>
        </view>
        <view wx:elif="{{item.myRole === 'passenger' && item.myStatus === 'confirmed'}}" class="trip-actions">
          <button class="btn-cancel" catch:tap="cancelApplication" data-id="{{item._id}}">取消申请</button>
        </view>
      </block>
    </view>
    <loading-more loading="{{loadingMore}}" hasMore="{{hasMore}}" />
  </view>

  <empty-state wx:elif="{{!initialLoading}}" icon="📋" title="暂无行程" desc="去发布或寻找一个行程吧" />
</view>
