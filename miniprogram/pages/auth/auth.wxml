<view class="page-container">
  <view class="auth-card card">
    <view class="auth-icon">🪪</view>
    <text class="auth-title">实名认证</text>
    <text class="auth-desc">为了保障行程安全，发布行程前需要完成实名认证。您的信息仅用于身份核验，不会被公开。</text>

    <view class="auth-form">
      <view class="form-section">
        <text class="form-label">👤 真实姓名</text>
        <input class="form-input" placeholder="请输入真实姓名"
          value="{{realName}}" bindinput="onInput" data-field="realName" maxlength="20" />
      </view>
      <view class="form-section">
        <text class="form-label">🆔 身份证号</text>
        <input class="form-input" placeholder="请输入身份证号"
          value="{{idCard}}" bindinput="onInput" data-field="idCard" maxlength="18" />
      </view>
    </view>

    <view class="auth-tips">
      <text class="tip-item">✔ 信息加密传输，保障隐私</text>
      <text class="tip-item">✔ 仅用于身份核验</text>
      <text class="tip-item">✔ 不存储明文身份证号</text>
    </view>

    <button class="btn-primary" bind:tap="submitAuth">提交认证</button>
  </view>
</view>