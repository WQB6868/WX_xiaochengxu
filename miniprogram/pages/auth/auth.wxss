.auth-card { padding: 50rpx 30rpx; text-align: center; }
.auth-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.auth-title { font-size: 36rpx; font-weight: 600; margin-bottom: 16rpx; }
.auth-desc { font-size: 26rpx; color: var(--text-secondary); line-height: 1.6; margin-bottom: 40rpx; }
.auth-form { text-align: left; margin-bottom: 30rpx; }
.auth-tips { text-align: left; margin-bottom: 40rpx; }
.tip-item { display: block; font-size: 24rpx; color: var(--text-hint); margin-bottom: 8rpx; }
