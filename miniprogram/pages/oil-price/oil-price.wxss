.province-bar {
  margin-bottom: 20rpx;
}
.province-scroll {
  white-space: nowrap;
  padding: 4rpx 0;
}
.province-tags {
  display: inline-flex;
  gap: 12rpx;
}
.province-tag {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: 48rpx;
  font-size: 26rpx;
  color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.province-tag.active {
  background: #07c160;
  color: #fff;
}

.region-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.price-card {
  margin-bottom: 16rpx;
  padding: 30rpx;
}
.price-row {
  display: flex;
  align-items: center;
}
.price-item {
  flex: 1;
  text-align: center;
  padding: 10rpx 0;
}
.price-divider {
  width: 2rpx;
  height: 100rpx;
  background: #f0f0f0;
  margin: 0 20rpx;
}
.fuel-type {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}
.fuel-price {
  font-size: 52rpx;
  font-weight: 700;
  color: #333;
  display: block;
  line-height: 1.1;
}
.fuel-unit {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}

.update-info {
  text-align: center;
  padding: 10rpx 0 20rpx;
}
.update-text {
  font-size: 22rpx;
  color: #ccc;
}

.note-card {
  margin-bottom: 16rpx;
}
.note-text {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 6rpx;
  line-height: 1.6;
}

.refresh-bar {
  padding: 10rpx 0 40rpx;
}

.loading-init {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.loading-spinner {
  width: 64rpx; height: 64rpx;
  border: 4rpx solid #e5e5e5;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #999;
}
.source-tag {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: rgba(7,193,96,0.1);
  color: #07c160;
  border-radius: 24rpx;
  margin-left: 12rpx;
  vertical-align: middle;
  font-weight: 400;
}

/* 娌逛环鏂伴椈骞挎挱 */
.news-marquee {
  display: flex;
  align-items: center;
  background: #fff8e1;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}
.news-icon {
  font-size: 28rpx;
  flex-shrink: 0;
  margin-right: 12rpx;
}
.marquee-wrapper {
  flex: 1;
  overflow: hidden;
  white-space: nowrap;
}
.marquee-text {
  display: inline-block;
  font-size: 24rpx;
  color: #b8860b;
  animation: marquee 30s linear infinite;
  padding-left: 100%;
  white-space: nowrap;
}
@keyframes marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-100%); }
}
/* 油价新闻弹窗 */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}
.modal-content {
  width: 100%;
  max-height: 70vh;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 30rpx 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}
.modal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.modal-close {
  font-size: 32rpx;
  color: #999;
  padding: 10rpx;
  line-height: 1;
}
.modal-body {
  padding: 30rpx;
  max-height: 55vh;
}
.modal-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.8;
}