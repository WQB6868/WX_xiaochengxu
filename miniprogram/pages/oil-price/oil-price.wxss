.province-bar {
  margin-bottom: 20rpx;
}
.province-scroll {
  white-space: nowrap;
  padding: 4rpx 0;
}
.province-tags {
  display: inline-flex;
  gap: 12rpx;
}
.province-tag {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: 48rpx;
  font-size: 26rpx;
  color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.province-tag.active {
  background: #07c160;
  color: #fff;
}

.region-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.price-card {
  margin-bottom: 16rpx;
  padding: 30rpx;
}
.price-row {
  display: flex;
  align-items: center;
}
.price-item {
  flex: 1;
  text-align: center;
  padding: 10rpx 0;
}
.price-divider {
  width: 2rpx;
  height: 100rpx;
  background: #f0f0f0;
  margin: 0 20rpx;
}
.fuel-type {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}
.fuel-price {
  font-size: 52rpx;
  font-weight: 700;
  color: #333;
  display: block;
  line-height: 1.1;
}
.fuel-unit {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}

.update-info {
  text-align: center;
  padding: 10rpx 0 20rpx;
}
.update-text {
  font-size: 22rpx;
  color: #ccc;
}

.note-card {
  margin-bottom: 16rpx;
}
.note-text {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 6rpx;
  line-height: 1.6;
}

.refresh-bar {
  padding: 10rpx 0 40rpx;
}

.loading-init {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.loading-spinner {
  width: 64rpx; height: 64rpx;
  border: 4rpx solid #e5e5e5;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #999;
}
.source-tag {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: rgba(7,193,96,0.1);
  color: #07c160;
  border-radius: 24rpx;
  margin-left: 12rpx;
  vertical-align: middle;
  font-weight: 400;
}