.vehicle-item { margin-bottom: 16rpx; }
.vehicle-main { display: flex; align-items: center; }
.vehicle-icon { font-size: 48rpx; margin-right: 20rpx; }
.vehicle-info { flex: 1; }
.vehicle-name { font-size: 30rpx; font-weight: 500; display: block; }
.vehicle-plate { font-size: 24rpx; color: var(--text-hint); margin-top: 4rpx; }
.vehicle-badge { font-size: 20rpx; padding: 4rpx 12rpx; background: var(--color-primary-light); color: var(--color-primary); border-radius: var(--radius-sm); }
.vehicle-actions { display: flex; justify-content: flex-end; gap: 24rpx; margin-top: 16rpx; padding-top: 16rpx; border-top: 2rpx solid var(--border-light); }
.action-btn { font-size: 26rpx; color: var(--color-blue); }
.action-btn.delete { color: var(--color-warning); }
.add-card { margin-top: 20rpx; }
