/* Search Card */
.search-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
}
.search-form {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.search-field-wrap { flex: 1; position: relative; z-index: 10; }
.search-field {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: var(--bg-input);
  border-radius: var(--radius-md);
  transition: all 0.2s;
  border: 2rpx solid transparent;
}
.search-field.focused { border-color: var(--color-primary); background: #fff; }
.field-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-right: 12rpx;
  flex-shrink: 0;
}
.field-input { flex: 1; font-size: 28rpx; height: 40rpx; min-height: 40rpx; color: var(--text-primary); }
.ph { font-size: 28rpx; color: var(--text-placeholder); }

/* City suggestion dropdown */
.city-suggest {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: var(--radius-md);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.12);
  max-height: 360rpx;
  overflow-y: auto;
  margin-top: 4rpx;
  z-index: 100;
}
.suggest-item {
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  border-bottom: 1rpx solid var(--border-color);
}
.suggest-item:active { background: #f0fdf4; }
.suggest-item:last-child { border-bottom: none; }
.suggest-city { color: var(--text-primary); }
.search-swap {
  font-size: 36rpx;
  color: var(--color-primary);
  padding: 10rpx;
  flex-shrink: 0;
  transition: transform 0.2s;
}
.search-swap:active { transform: rotate(180deg); }

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.date-picker { flex: 1; }
.date-selector {
  display: flex;
  align-items: center;
  background: var(--bg-input);
  border-radius: var(--radius-md);
  padding: 16rpx 20rpx;
}
.date-icon { font-size: 28rpx; margin-right: 8rpx; }
.date-text { font-size: 26rpx; color: var(--text-primary); }
.date-text.placeholder { color: var(--text-placeholder); }
.search-btn {
  flex-shrink: 0;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 40rpx;
  margin-top: 0;
}

/* Route Tags */
.route-scroll { margin-bottom: 16rpx; white-space: nowrap; }
.route-tags { display: inline-flex; gap: 16rpx; padding: 4rpx 0; }
.route-tag {
  position: relative;
  display: inline-flex;
  align-items: center;
  padding: 14rpx 28rpx;
  background: #fff;
  border-radius: var(--radius-round);
  font-size: 24rpx;
  box-shadow: var(--shadow-card);
  gap: 8rpx;
  transition: all 0.25s ease;
  overflow: hidden;
}
.route-tag:active { transform: scale(0.95); }
.route-tag.active {
  background: var(--color-primary);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.35);
  transform: scale(1.05);
  font-weight: 600;
}
.route-arrow { color: var(--text-hint); font-size: 20rpx; transition: color 0.25s; }
.route-tag.active .route-arrow { color: rgba(255,255,255,0.7); }
.route-tag.active .route-from,
.route-tag.active .route-to { color: #fff; }
.active-dot {
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 12rpx;
  height: 12rpx;
  background: rgba(255,255,255,0.8);
  border-radius: 50%;
}

/* Date Tags */
.date-scroll { margin-bottom: 24rpx; white-space: nowrap; }
.date-tags { display: inline-flex; gap: 12rpx; padding: 4rpx 0; }
.date-tag {
  position: relative;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 32rpx;
  background: #fff;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  min-width: 110rpx;
  transition: all 0.25s ease;
  overflow: hidden;
}
.date-tag:active { transform: scale(0.95); }
.date-tag.active {
  background: linear-gradient(180deg, var(--color-primary), #059669);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.4);
  transform: translateY(-4rpx);
}
.date-week { font-size: 22rpx; font-weight: 500; transition: color 0.25s; }
.date-day { font-size: 28rpx; margin-top: 6rpx; font-weight: 600; transition: color 0.25s; }
.date-tag.active .date-week,
.date-tag.active .date-day { color: #fff; }
.active-indicator {
  position: absolute;
  bottom: 0;
  left: 20%;
  width: 60%;
  height: 4rpx;
  background: rgba(255,255,255,0.6);
  border-radius: 4rpx 4rpx 0 0;
}

/* Trip List */
.trip-list { padding-bottom: 160rpx; }
.result-count { font-size: 24rpx; color: var(--text-hint); margin-bottom: 16rpx; }

/* Loading */
.loading-init {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}
.loading-spinner {
  width: 64rpx; height: 64rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { margin-top: 20rpx; font-size: 26rpx; color: var(--text-hint); }

/* FAB */
.fab-container {
  position: fixed;
  right: 30rpx;
  bottom: 120rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 100;
}
.fab {
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
  border-radius: var(--radius-round);
  box-shadow: var(--shadow-elevated);
  font-size: 26rpx;
  gap: 8rpx;
  transition: transform 0.2s;
}
.fab:active { transform: scale(0.92); }
.fab-primary { background: var(--color-primary); color: #fff; }
.fab-secondary { background: #fff; color: var(--text-primary); }
.fab-icon { font-size: 32rpx; }
/* Initial Prompt */
.initial-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
  padding-bottom: 60rpx;
}
.prompt-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.prompt-title { font-size: 32rpx; font-weight: 600; color: var(--text-primary); margin-bottom: 12rpx; }
.prompt-desc { font-size: 26rpx; color: var(--text-hint); margin-bottom: 48rpx; text-align: center; padding: 0 60rpx; }
.prompt-steps { display: flex; flex-direction: column; gap: 24rpx; }
.prompt-step { display: flex; align-items: center; gap: 16rpx; }
.step-num {
  width: 40rpx; height: 40rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.step-text { font-size: 26rpx; color: var(--text-secondary); }

/* 内联卡片样式 */
.inline-card { background: #fff; border-radius: 16rpx; padding: 28rpx 24rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.inline-card .card-row { display: flex; align-items: center; padding: 8rpx 0; }
.inline-card .route-row { margin-bottom: 6rpx; }
.inline-card .city-from, .inline-card .city-to { font-size: 34rpx; font-weight: 700; color: #1a1a1a; }
.inline-card .route-arrow { font-size: 28rpx; color: #999; margin: 0 12rpx; }
.inline-card .date-text { font-size: 28rpx; color: #666; }
.inline-card .seats-text { font-size: 28rpx; color: #fa9a3e; font-weight: 600; }
