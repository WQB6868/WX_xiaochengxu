/* ===== CSS Variables ===== */
:root, page {
  --color-primary: #07c160;
  --color-primary-light: rgba(7, 193, 96, 0.1);
  --color-orange: #fa9a3e;
  --color-warning: #fa5151;
  --color-blue: #10aeff;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --text-placeholder: #cccccc;
  --bg-page: #f5f5f5;
  --bg-input: #f7f7f7;
  --border-color: #e5e5e5;
  --border-light: #f0f0f0;
  --shadow-card: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  --shadow-elevated: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  --radius-sm: 4rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-round: 48rpx;
}
