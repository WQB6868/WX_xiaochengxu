.loading-more, .no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
}
.loading-spinner {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #e5e5e5;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 12rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text, .no-more-text {
  font-size: 24rpx;
  color: #ccc;
}
