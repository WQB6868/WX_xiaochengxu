.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.dialog {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
}
.dialog-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  display: block;
  margin-bottom: 16rpx;
}
.dialog-content {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  display: block;
  margin-bottom: 40rpx;
  line-height: 1.5;
}
.dialog-actions {
  display: flex;
  gap: 20rpx;
}
.dialog-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}
.dialog-btn.cancel {
  background: #f5f5f5;
  color: #666;
}
.dialog-btn.confirm {
  background: #f5f5f5;
  font-weight: 600;
}
