@import "miniprogram/assets/styles/variables.wxss";
@import "miniprogram/assets/styles/reset.wxss";

page {
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg-page);
}

::-webkit-scrollbar { display: none; }

.btn-primary {
  background-color: var(--color-primary) !important;
  color: #fff !important;
  border-radius: 48rpx !important;
  font-size: 30rpx !important;
  padding: 20rpx 40rpx !important;
  border: none !important;
  width: 100%;
}
.btn-primary:active { opacity: 0.85; }

.btn-secondary {
  background-color: #fff !important;
  color: var(--color-primary) !important;
  border-radius: 48rpx !important;
  font-size: 30rpx !important;
  padding: 20rpx 40rpx !important;
  border: 2rpx solid var(--color-primary) !important;
  width: 100%;
}

.btn-danger {
  background-color: #fa5151 !important;
  color: #fff !important;
  border-radius: 48rpx !important;
  font-size: 30rpx !important;
  padding: 20rpx 40rpx !important;
  border: none !important;
  width: 100%;
}

.page-container { padding: 30rpx; min-height: 100vh; }
.section-title { font-size: 32rpx; font-weight: 600; margin-bottom: 20rpx; }
.card { background: #fff; border-radius: 16rpx; padding: 30rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.tag { display: inline-block; padding: 6rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; color: var(--color-primary); background-color: var(--color-primary-light); margin-right: 10rpx; margin-bottom: 10rpx; }
.form-label { font-size: 28rpx; font-weight: 500; margin-bottom: 16rpx; display: block; }
.form-input { width: 100%; height: 72rpx; background: var(--bg-input); border-radius: 12rpx; padding: 0 24rpx; font-size: 28rpx; border: 2rpx solid var(--border-color); box-sizing: border-box; }
.form-input:focus { border-color: var(--color-primary); }
.safe-area-bottom { padding-bottom: env(safe-area-inset-bottom); }
